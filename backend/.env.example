# TranscriptPro Backend Configuration

# Security — shared secret with Vercel frontend
API_SECRET=change-me-to-a-random-string

# Redis (Docker internal network)
REDIS_URL=redis://redis:6379/0

# Whisper model (tiny/base/small/medium/large)
WHISPER_MODEL=small

# yt-dlp proxy for YouTube downloads (IPRoyal residential proxy)
PROXY_URL=http://user:pass@geo.iproyal.com:12321

# Worker concurrency (adjust based on CPU cores)
WORKER_CONCURRENCY=4
